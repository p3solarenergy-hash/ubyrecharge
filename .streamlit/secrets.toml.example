# ── Credenciais Google Sheets (Service Account) ───────────────────────────────
# Renomeie este arquivo para secrets.toml e preencha com os dados reais.
# NÃO commite o secrets.toml no Git — ele já está no .gitignore.
#
# Como obter:
#  1. Google Cloud Console → IAM → Service Accounts → Criar conta
#  2. Baixar chave JSON
#  3. Copiar cada campo do JSON aqui abaixo
#  4. Compartilhar a planilha com o client_email como Leitor

[gcp_service_account]
type                        = "service_account"
project_id                  = "SEU_PROJECT_ID"
private_key_id              = "SEU_KEY_ID"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\nCONTEUDO_DA_CHAVE\n-----END RSA PRIVATE KEY-----\n"
client_email                = "p3energy@SEU_PROJECT.iam.gserviceaccount.com"
client_id                   = "SEU_CLIENT_ID"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/p3energy%40SEU_PROJECT.iam.gserviceaccount.com"
